<Window x:Class="Scrcap.Windows.UI.Onboarding.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Welcome to scrcap"
        Width="{StaticResource MetricOnboardingWidth}"
        Height="{StaticResource MetricOnboardingHeight}"
        MinWidth="{StaticResource MetricOnboardingWidth}"
        MinHeight="{StaticResource MetricOnboardingHeight}"
        MaxWidth="{StaticResource MetricOnboardingWidth}"
        MaxHeight="{StaticResource MetricOnboardingHeight}"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushChrome}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="{StaticResource MetricPreferencesRadius}"
                        GlassFrameThickness="0"
                        NonClientFrameEdges="None"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="OnboardingButton" TargetType="Button">
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource MetricChromeButtonRadius}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushHover}" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushPressed}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border CornerRadius="{StaticResource MetricPreferencesRadius}"
          Background="{DynamicResource BrushWindowFrame}"
          Margin="{StaticResource MetricWindowChromeInset}"
          SnapsToDevicePixels="True"
          MouseLeftButtonDown="WindowBackground_MouseLeftButtonDown">
    <Border CornerRadius="{StaticResource MetricPreferencesInnerRadius}"
            Background="{DynamicResource BrushChrome}"
            Margin="{StaticResource MetricWindowFrameThickness}"
            SnapsToDevicePixels="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="{StaticResource MetricOnboardingHeaderHeight}" />
        <RowDefinition Height="*" />
        <RowDefinition Height="{StaticResource MetricOnboardingFooterHeight}" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            Background="{DynamicResource BrushChrome}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Rectangle Grid.ColumnSpan="2"
                   VerticalAlignment="Bottom"
                   Height="{StaticResource MetricSeparatorWidth}"
                   Fill="{DynamicResource BrushRule}" />
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="{StaticResource MetricHeaderBrandMargin}">
          <Border Width="{StaticResource MetricLogoGlyphSize}"
                  Height="{StaticResource MetricLogoGlyphSize}"
                  BorderBrush="{DynamicResource BrushInk}"
                  BorderThickness="{StaticResource MetricBorderThickness}"
                  CornerRadius="{StaticResource MetricLogoRadius}"
                  Margin="{StaticResource MetricLogoMargin}">
          <Grid>
              <Rectangle Width="{StaticResource MetricLogoDotSize}" Height="{StaticResource MetricLogoDotSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Rectangle Width="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" />
              <Rectangle Height="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" VerticalAlignment="Center" />
          </Grid>
        </Border>
          <TextBlock Text="SCRCAP"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeBrand}"
                     FontWeight="Black"
                     Foreground="{DynamicResource BrushInk}" />
          <TextBlock Text="Welcome"
                     VerticalAlignment="Center"
                     Margin="{StaticResource MetricPreferencesSubtitleMargin}"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeSmall}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushMuted}" />
        </StackPanel>
        <Button Grid.Column="1"
                AutomationProperties.AutomationId="CloseOnboarding"
                AutomationProperties.Name="Close onboarding"
                Content="&#xE711;"
                FontFamily="{StaticResource FontIcon}"
                Width="{StaticResource MetricIconButtonWidth}"
                Height="{StaticResource MetricIconButtonHeight}"
                Margin="{StaticResource MetricPreferencesCloseMargin}"
                Style="{StaticResource OnboardingButton}"
                Padding="{StaticResource MetricNoThickness}"
                Click="Later_Click" />
      </Grid>

    <StackPanel Grid.Row="1" Margin="{StaticResource MetricOnboardingContentMargin}">
      <TextBlock Text="Welcome to scrcap"
                 FontSize="{StaticResource FontSizeHeadline}"
                 FontWeight="Bold"
                 TextAlignment="Center" />
      <TextBlock Text="Screenshot, marked up, done."
                 Margin="{StaticResource MetricOnboardingSubtitleMargin}"
                 FontSize="{StaticResource FontSizeSubtitle}"
                 Foreground="{DynamicResource BrushMuted}"
                 TextAlignment="Center" />

      <StackPanel Margin="{StaticResource MetricOnboardingFeaturesMargin}">
        <Grid Margin="{StaticResource MetricOnboardingFeatureMargin}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureColumnWidth}" />
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureGap}" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="{StaticResource MetricOnboardingFeatureSize}" Height="{StaticResource MetricOnboardingFeatureSize}" Background="{DynamicResource BrushActiveWash}" CornerRadius="{StaticResource MetricOnboardingFeatureRadius}">
            <TextBlock Text="&#xE722;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeBrand}" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="It lives in your system tray" FontSize="{StaticResource FontSizeToolbarTextIcon}" FontWeight="SemiBold" />
            <TextBlock Text="Use the tray icon for capture modes, preferences, and quit." FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource BrushMuted}" />
          </StackPanel>
        </Grid>

        <Grid Margin="{StaticResource MetricOnboardingFeatureMargin}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureColumnWidth}" />
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureGap}" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="{StaticResource MetricOnboardingFeatureSize}" Height="{StaticResource MetricOnboardingFeatureSize}" Background="{DynamicResource BrushActiveWash}" CornerRadius="{StaticResource MetricOnboardingFeatureRadius}">
            <TextBlock Text="&#xE922;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeBrand}" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Grab a region in one press" FontSize="{StaticResource FontSizeToolbarTextIcon}" FontWeight="SemiBold" />
              <Border Margin="{StaticResource MetricOnboardingShortcutMargin}" Padding="{StaticResource MetricOnboardingShortcutPadding}" BorderBrush="{DynamicResource BrushRule}" BorderThickness="{StaticResource MetricBorderThickness}" CornerRadius="{StaticResource MetricOnboardingShortcutRadius}">
                <TextBlock Text="{Binding RegionShortcut}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" />
              </Border>
            </StackPanel>
            <TextBlock Text="Try it anywhere - the rest of the shortcuts are in the tray menu." FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource BrushMuted}" />
          </StackPanel>
        </Grid>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureColumnWidth}" />
            <ColumnDefinition Width="{StaticResource MetricOnboardingFeatureGap}" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="{StaticResource MetricOnboardingFeatureSize}" Height="{StaticResource MetricOnboardingFeatureSize}" Background="{DynamicResource BrushActiveWash}" CornerRadius="{StaticResource MetricOnboardingFeatureRadius}">
            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeBrand}" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Mark up, then copy or save" FontSize="{StaticResource FontSizeToolbarTextIcon}" FontWeight="SemiBold" />
            <TextBlock Text="Arrows, text, counters, pixelate - then Ctrl+C or Ctrl+S." FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource BrushMuted}" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="2" Background="{DynamicResource BrushWell}" BorderBrush="{DynamicResource BrushHairline}" BorderThickness="0,1,0,0">
      <StackPanel Margin="{StaticResource MetricOnboardingFooterMargin}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE72E;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeToolbarTextIcon}" Foreground="{DynamicResource BrushMuted}" Margin="{StaticResource MetricOnboardingPrivacyIconMargin}" />
          <TextBlock Text="scrcap captures only when you use a shortcut or the tray menu."
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{DynamicResource BrushMuted}" />
        </StackPanel>
        <DockPanel Margin="{StaticResource MetricOnboardingActionsMargin}" LastChildFill="False">
          <Button Content="Preferences..."
                  Style="{StaticResource OnboardingButton}"
                  DockPanel.Dock="Left"
                  Click="Preferences_Click" />
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <Button Content="Later"
                    Style="{StaticResource OnboardingButton}"
                    Click="Later_Click" />
          </StackPanel>
        </DockPanel>
      </StackPanel>
    </Border>
    </Grid>
    </Border>
  </Border>
</Window>
