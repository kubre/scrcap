<Window x:Class="Scrcap.Windows.UI.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="clr-namespace:Scrcap.Windows.UI.Editor"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="scrcap"
        Width="{StaticResource MetricEditorWidth}"
        Height="{StaticResource MetricEditorHeight}"
        MinWidth="{StaticResource MetricEditorMinWidth}"
        MinHeight="{StaticResource MetricEditorMinHeight}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushChrome}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="{StaticResource MetricEditorRadius}"
                        GlassFrameThickness="0"
                        NonClientFrameEdges="None"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <editor:BooleanResourceBrushConverter x:Key="ToolbarActiveBackground"
                                          TrueResourceKey="BrushActiveWash" />
    <editor:BooleanResourceBrushConverter x:Key="ToolbarIconForeground"
                                          TrueResourceKey="BrushAccent"
                                          FalseResourceKey="BrushInk" />
    <editor:BooleanResourceBrushConverter x:Key="ToolbarKeyForeground"
                                          TrueResourceKey="BrushAccent"
                                          FalseResourceKey="BrushMuted" />

    <Style x:Key="ChromeButton" TargetType="Button">
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource MetricChromeButtonRadius}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource BrushHover}" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource BrushPressed}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolbarButton" TargetType="Button">
      <Setter Property="MinWidth" Value="{StaticResource MetricToolbarButtonMinWidth}" />
      <Setter Property="Height" Value="{StaticResource MetricToolbarButtonHeight}" />
      <Setter Property="Margin" Value="{StaticResource MetricToolbarButtonMargin}" />
      <Setter Property="Padding" Value="{StaticResource MetricToolbarButtonPadding}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonChrome"
                    Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ToolbarActiveBackground}}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource BrushHover}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource BrushPressed}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolbarKeyText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarKeyForeground}}" />
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ToolbarIconText" TargetType="TextBlock">
      <Setter Property="FontSize" Value="19" />
      <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ToolbarIconViewbox" TargetType="Viewbox">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ToolbarStrokeIcon" TargetType="Path">
      <Setter Property="Stroke" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
      <Setter Property="StrokeThickness" Value="1.65" />
      <Setter Property="StrokeStartLineCap" Value="Round" />
      <Setter Property="StrokeEndLineCap" Value="Round" />
      <Setter Property="StrokeLineJoin" Value="Round" />
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ToolbarFillIcon" TargetType="Shape">
      <Setter Property="Fill" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ToolbarCounterIconText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
      <Setter Property="FontSize" Value="8.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ToolbarDot" TargetType="Ellipse">
      <Setter Property="Fill" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

  </Window.Resources>

  <Border CornerRadius="{StaticResource MetricEditorRadius}"
          Background="{DynamicResource BrushWindowFrame}"
          Margin="{StaticResource MetricWindowChromeInset}"
          SnapsToDevicePixels="True">
    <Border CornerRadius="{StaticResource MetricEditorInnerRadius}"
            Background="{DynamicResource BrushChrome}"
            Margin="{StaticResource MetricWindowFrameThickness}"
            SnapsToDevicePixels="True">
    <Grid>
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top"
              Height="{StaticResource MetricHeaderHeight}"
              Background="{DynamicResource BrushChrome}"
              MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Rectangle Grid.ColumnSpan="3"
                   VerticalAlignment="Bottom"
                   Height="{StaticResource MetricSeparatorWidth}"
                   Fill="{DynamicResource BrushRule}" />
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MetricHeaderBrandMargin}">
          <Border Width="{StaticResource MetricLogoGlyphSize}"
                  Height="{StaticResource MetricLogoGlyphSize}"
                  BorderBrush="{DynamicResource BrushInk}"
                  BorderThickness="{StaticResource MetricBorderThickness}"
                  CornerRadius="{StaticResource MetricLogoRadius}"
                  Margin="{StaticResource MetricLogoMargin}">
            <Grid>
              <Rectangle Width="{StaticResource MetricLogoDotSize}" Height="{StaticResource MetricLogoDotSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Rectangle Width="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" />
              <Rectangle Height="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <TextBlock Text="SCRCAP"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeBrand}"
                     FontWeight="Black"
                     Foreground="{DynamicResource BrushInk}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MetricHeaderRightMargin}">
          <Button AutomationProperties.AutomationId="UndoButton"
                  AutomationProperties.Name="Undo"
                  Style="{StaticResource ChromeButton}"
                  ToolTip="Undo"
                  Click="Undo_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7A7;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeChromeIcon}" />
              <TextBlock Text="Ctrl+Z" FontFamily="{StaticResource FontMono}" Foreground="{DynamicResource BrushMuted}" Margin="{StaticResource MetricShortcutTextMargin}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="SaveButton"
                  AutomationProperties.Name="Save"
                  Style="{StaticResource ChromeButton}"
                  ToolTip="Save"
                  Click="Save_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeChromeIcon}" />
              <TextBlock Text="Ctrl+S" FontFamily="{StaticResource FontMono}" Foreground="{DynamicResource BrushMuted}" Margin="{StaticResource MetricShortcutTextMargin}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="DoneButton"
                  AutomationProperties.Name="Copy and close"
                  Style="{StaticResource ChromeButton}"
                  MinWidth="{StaticResource MetricDoneButtonMinWidth}"
                  Click="Done_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding DoneText}" FontFamily="{StaticResource FontMono}" FontWeight="Bold" />
              <TextBlock Text="esc" FontFamily="{StaticResource FontMono}" Foreground="{DynamicResource BrushMuted}" Margin="{StaticResource MetricDoneShortcutMargin}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="CloseButton"
                  AutomationProperties.Name="Close"
                  Style="{StaticResource ChromeButton}"
                  Width="{StaticResource MetricIconButtonWidth}"
                  Padding="{StaticResource MetricNoThickness}"
                  Click="Close_Click">
            <TextBlock Text="&#xE711;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeCloseIcon}" />
          </Button>
        </StackPanel>
      </Grid>

      <Grid DockPanel.Dock="Bottom"
            Height="{StaticResource MetricToolbarHeight}"
            Background="{DynamicResource BrushChrome}"
            MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Rectangle Grid.ColumnSpan="2"
                   VerticalAlignment="Top"
                   Height="{StaticResource MetricSeparatorWidth}"
                   Fill="{DynamicResource BrushRule}" />
        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" Margin="{StaticResource MetricToolbarInnerMargin}">
          <Button AutomationProperties.AutomationId="ToolArrow" AutomationProperties.Name="Arrow tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsArrowToolActive}" Click="ToolArrow_Click">
            <StackPanel Orientation="Horizontal">
              <Viewbox Style="{StaticResource ToolbarIconViewbox}">
                <Canvas Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}">
                  <Path Style="{StaticResource ToolbarStrokeIcon}" Data="M 4.5,4.5 L 11,11 M 4.5,4.5 H 10 M 4.5,4.5 V 10" />
                </Canvas>
              </Viewbox>
              <TextBlock Text="Q" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="ToolRectangle" AutomationProperties.Name="Rectangle tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsRectangleToolActive}" Click="ToolRectangle_Click">
            <StackPanel Orientation="Horizontal">
              <Viewbox Style="{StaticResource ToolbarIconViewbox}">
                <Canvas Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}">
                  <Path Style="{StaticResource ToolbarStrokeIcon}" Data="M 3.5,4.5 H 11.5 V 10.5 H 3.5 Z" />
                </Canvas>
              </Viewbox>
              <TextBlock Text="W" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="ToolCounter" AutomationProperties.Name="Counter tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsCounterToolActive}" Click="ToolCounter_Click">
            <StackPanel Orientation="Horizontal">
              <Grid Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}" VerticalAlignment="Center">
                <Ellipse Width="{StaticResource MetricToolbarCounterGlyphSize}" Height="{StaticResource MetricToolbarCounterGlyphSize}" StrokeThickness="1.55" Stroke="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}" />
                <TextBlock Text="1" Style="{StaticResource ToolbarCounterIconText}" Margin="0,-0.5,0,0" />
              </Grid>
              <TextBlock Text="E" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="ToolText" AutomationProperties.Name="Text tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsTextToolActive}" Click="ToolText_Click">
            <StackPanel Orientation="Horizontal">
              <Grid Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}" VerticalAlignment="Center">
                <TextBlock Text="T"
                           FontFamily="{StaticResource FontUi}"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ToolbarIconForeground}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,-1,0,0" />
                <Path Style="{StaticResource ToolbarStrokeIcon}" Data="M 4,12.25 H 11" StrokeThickness="1.25" />
              </Grid>
              <TextBlock Text="R" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="ToolPixelate" AutomationProperties.Name="Pixelate tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsPixelateToolActive}" Click="ToolPixelate_Click">
            <StackPanel Orientation="Horizontal">
              <Grid Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}" VerticalAlignment="Center">
                <UniformGrid Width="{StaticResource MetricPixelateGlyphGridSize}"
                             Height="{StaticResource MetricPixelateGlyphGridSize}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Columns="3"
                             Rows="3">
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" Opacity="0.72" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" Opacity="0.72" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" Opacity="0.72" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" Opacity="0.72" />
                  <Rectangle Width="{StaticResource MetricPixelateGlyphCellSize}" Height="{StaticResource MetricPixelateGlyphCellSize}" Style="{StaticResource ToolbarFillIcon}" />
                </UniformGrid>
              </Grid>
              <TextBlock Text="T" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="ToolCrop" AutomationProperties.Name="Crop tool" Style="{StaticResource ToolbarButton}" Tag="{Binding IsCropToolActive}" Click="ToolCrop_Click">
            <StackPanel Orientation="Horizontal">
              <Viewbox Style="{StaticResource ToolbarIconViewbox}">
                <Canvas Width="{StaticResource MetricToolbarGlyphSize}" Height="{StaticResource MetricToolbarGlyphSize}">
                  <Path Style="{StaticResource ToolbarStrokeIcon}" Data="M 5,2.5 V 10 H 12.5 M 2.5,5 H 10 V 12.5" />
                </Canvas>
              </Viewbox>
              <TextBlock Text="Y" Style="{StaticResource ToolbarKeyText}" />
            </StackPanel>
          </Button>
          <Rectangle Width="{StaticResource MetricSeparatorWidth}" Height="{StaticResource MetricSeparatorHeight}" Fill="{DynamicResource BrushHairline}" Margin="{StaticResource MetricSeparatorMargin}" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="Color1" AutomationProperties.Name="Palette color 1" Style="{StaticResource ToolbarButton}" Tag="{Binding IsColor1Active}" Click="Color1_Click">
            <StackPanel Orientation="Horizontal"><Rectangle Width="{StaticResource MetricSwatchSize}" Height="{StaticResource MetricSwatchSize}" Fill="{Binding PaletteBrushes[0]}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" /><TextBlock Text="1" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="Color2" AutomationProperties.Name="Palette color 2" Style="{StaticResource ToolbarButton}" Tag="{Binding IsColor2Active}" Click="Color2_Click">
            <StackPanel Orientation="Horizontal"><Rectangle Width="{StaticResource MetricSwatchSize}" Height="{StaticResource MetricSwatchSize}" Fill="{Binding PaletteBrushes[1]}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" /><TextBlock Text="2" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="Color3" AutomationProperties.Name="Palette color 3" Style="{StaticResource ToolbarButton}" Tag="{Binding IsColor3Active}" Click="Color3_Click">
            <StackPanel Orientation="Horizontal"><Rectangle Width="{StaticResource MetricSwatchSize}" Height="{StaticResource MetricSwatchSize}" Fill="{Binding PaletteBrushes[2]}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" /><TextBlock Text="3" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="Color4" AutomationProperties.Name="Palette color 4" Style="{StaticResource ToolbarButton}" Tag="{Binding IsColor4Active}" Click="Color4_Click">
            <StackPanel Orientation="Horizontal"><Rectangle Width="{StaticResource MetricSwatchSize}" Height="{StaticResource MetricSwatchSize}" Fill="{Binding PaletteBrushes[3]}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" /><TextBlock Text="4" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="Color5" AutomationProperties.Name="Palette color 5" Style="{StaticResource ToolbarButton}" Tag="{Binding IsColor5Active}" Click="Color5_Click">
            <StackPanel Orientation="Horizontal"><Rectangle Width="{StaticResource MetricSwatchSize}" Height="{StaticResource MetricSwatchSize}" Fill="{Binding PaletteBrushes[4]}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" /><TextBlock Text="5" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Rectangle Width="{StaticResource MetricSeparatorWidth}" Height="{StaticResource MetricSeparatorHeight}" Fill="{DynamicResource BrushHairline}" Margin="{StaticResource MetricSeparatorMargin}" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="SizeSmall" AutomationProperties.Name="Small annotation size" Style="{StaticResource ToolbarButton}" Tag="{Binding IsSmallSizeActive}" Click="SizeSmall_Click">
            <StackPanel Orientation="Horizontal"><Ellipse Width="{StaticResource MetricSmallDotSize}" Height="{StaticResource MetricSmallDotSize}" Style="{StaticResource ToolbarDot}" /><TextBlock Text="Z" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="SizeMedium" AutomationProperties.Name="Medium annotation size" Style="{StaticResource ToolbarButton}" Tag="{Binding IsMediumSizeActive}" Click="SizeMedium_Click">
            <StackPanel Orientation="Horizontal"><Ellipse Width="{StaticResource MetricMediumDotSize}" Height="{StaticResource MetricMediumDotSize}" Style="{StaticResource ToolbarDot}" /><TextBlock Text="X" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
          <Button AutomationProperties.AutomationId="SizeLarge" AutomationProperties.Name="Large annotation size" Style="{StaticResource ToolbarButton}" Tag="{Binding IsLargeSizeActive}" Click="SizeLarge_Click">
            <StackPanel Orientation="Horizontal"><Ellipse Width="{StaticResource MetricLargeDotSize}" Height="{StaticResource MetricLargeDotSize}" Style="{StaticResource ToolbarDot}" /><TextBlock Text="C" Style="{StaticResource ToolbarKeyText}" /></StackPanel>
          </Button>
        </StackPanel>
      </Grid>

        <Grid Background="{DynamicResource BrushCanvas}"
              ClipToBounds="True">
          <editor:EditorCanvas x:Name="Canvas"
                               Focusable="True"
                               ClipToBounds="True"
                               Margin="{StaticResource MetricCanvasMargin}"
                               ViewModel="{Binding}" />
        </Grid>
      </DockPanel>
      <Border HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="{StaticResource MetricZoomPillMargin}"
              Padding="{StaticResource MetricZoomPillPadding}"
              Background="{DynamicResource BrushChrome}"
              BorderBrush="{DynamicResource BrushRule}"
              BorderThickness="{StaticResource MetricBorderThickness}"
              CornerRadius="{StaticResource MetricZoomPillRadius}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Button AutomationProperties.AutomationId="ZoomOutButton"
                  AutomationProperties.Name="Zoom out"
                  Style="{StaticResource ChromeButton}"
                  Width="{StaticResource MetricZoomButtonWidth}"
                  Padding="{StaticResource MetricNoThickness}"
                  Click="ZoomOut_Click">
            <TextBlock Text="&#xE71F;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeToolbarTextIcon}" />
          </Button>
          <Button AutomationProperties.AutomationId="ZoomResetButton"
                  AutomationProperties.Name="Reset zoom"
                  Style="{StaticResource ChromeButton}"
                  MinWidth="{StaticResource MetricZoomResetMinWidth}"
                  Click="ZoomReset_Click">
            <TextBlock Text="{Binding ZoomPercent}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeZoomText}" FontWeight="Bold" />
          </Button>
          <Button AutomationProperties.AutomationId="ZoomInButton"
                  AutomationProperties.Name="Zoom in"
                  Style="{StaticResource ChromeButton}"
                  Width="{StaticResource MetricZoomButtonWidth}"
                  Padding="{StaticResource MetricNoThickness}"
                  Margin="{StaticResource MetricZoomInMargin}"
                  Click="ZoomIn_Click">
            <TextBlock Text="&#xE8A3;" FontFamily="{StaticResource FontIcon}" FontSize="{StaticResource FontSizeToolbarTextIcon}" />
          </Button>
          <Rectangle Width="{StaticResource MetricSeparatorWidth}" Height="{StaticResource MetricSeparatorHeight}" Fill="{DynamicResource BrushHairline}" Margin="{StaticResource MetricZoomDividerMargin}" />
          <TextBlock AutomationProperties.AutomationId="ZoomStatus"
                     VerticalAlignment="Center"
                     MinWidth="{StaticResource MetricDocumentSizeMinWidth}"
                     FontFamily="{StaticResource FontMono}"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource BrushMuted}"
                     Text="{Binding DocumentSizeText}" />
        </StackPanel>
      </Border>
    </Grid>
    </Border>
  </Border>
</Window>
