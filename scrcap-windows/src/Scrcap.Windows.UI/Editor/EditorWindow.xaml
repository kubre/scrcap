<Window x:Class="Scrcap.Windows.UI.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="clr-namespace:Scrcap.Windows.UI.Editor"
        Title="scrcap"
        Width="{StaticResource MetricEditorWidth}"
        Height="{StaticResource MetricEditorHeight}"
        MinWidth="{StaticResource MetricEditorMinWidth}"
        MinHeight="{StaticResource MetricEditorMinHeight}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushChrome}">
  <Window.Resources>
    <Style x:Key="ToolbarButton" TargetType="Button">
      <Setter Property="MinWidth" Value="{StaticResource MetricToolbarButtonMinWidth}" />
      <Setter Property="Height" Value="{StaticResource MetricToolbarButtonHeight}" />
      <Setter Property="Margin" Value="{StaticResource MetricToolbarButtonMargin}" />
      <Setter Property="Padding" Value="{StaticResource MetricToolbarButtonPadding}" />
      <Setter Property="Background" Value="{StaticResource BrushPanel}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushRule}" />
      <Setter Property="Foreground" Value="{StaticResource BrushInk}" />
    </Style>
  </Window.Resources>
  <Border BorderBrush="{StaticResource BrushRule}"
          BorderThickness="{StaticResource MetricBorderThickness}"
          CornerRadius="{StaticResource MetricEditorRadius}"
          Background="{StaticResource BrushChrome}">
    <DockPanel LastChildFill="True">
      <Grid DockPanel.Dock="Top"
            Height="{StaticResource MetricHeaderHeight}"
            Background="{StaticResource BrushPanel}"
            MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MetricHeaderMargin}">
          <TextBlock Text="scrcap"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeBody}"
                     FontWeight="Bold"
                     Foreground="{StaticResource BrushInk}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MetricHeaderRightMargin}">
          <Button AutomationProperties.AutomationId="UndoButton"
                  AutomationProperties.Name="Undo"
                  Style="{StaticResource ToolbarButton}"
                  Content="↶"
                  ToolTip="Undo"
                  Click="Undo_Click" />
          <Button AutomationProperties.AutomationId="SaveButton"
                  AutomationProperties.Name="Save"
                  Style="{StaticResource ToolbarButton}"
                  Content="💾"
                  ToolTip="Save"
                  Click="Save_Click" />
          <Button AutomationProperties.AutomationId="DoneButton"
                  AutomationProperties.Name="Copy and close"
                  Style="{StaticResource ToolbarButton}"
                  Content="{Binding DoneText}"
                  Click="Done_Click" />
          <Button AutomationProperties.AutomationId="CloseButton"
                  AutomationProperties.Name="Close"
                  Style="{StaticResource ToolbarButton}"
                  Content="×"
                  Click="Close_Click" />
        </StackPanel>
      </Grid>

      <Grid DockPanel.Dock="Bottom"
            Height="{StaticResource MetricToolbarHeight}"
            Background="{StaticResource BrushPanel}"
            MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MetricHeaderMargin}">
          <Button AutomationProperties.AutomationId="ToolArrow" AutomationProperties.Name="Arrow tool" Style="{StaticResource ToolbarButton}" Content="↗ Q" Click="ToolArrow_Click" />
          <Button AutomationProperties.AutomationId="ToolRectangle" AutomationProperties.Name="Rectangle tool" Style="{StaticResource ToolbarButton}" Content="▭ W" Click="ToolRectangle_Click" />
          <Button AutomationProperties.AutomationId="ToolCounter" AutomationProperties.Name="Counter tool" Style="{StaticResource ToolbarButton}" Content="① E" Click="ToolCounter_Click" />
          <Button AutomationProperties.AutomationId="ToolText" AutomationProperties.Name="Text tool" Style="{StaticResource ToolbarButton}" Content="T R" Click="ToolText_Click" />
          <Button AutomationProperties.AutomationId="ToolPixelate" AutomationProperties.Name="Pixelate tool" Style="{StaticResource ToolbarButton}" Content="▦ T" Click="ToolPixelate_Click" />
          <Button AutomationProperties.AutomationId="ToolCrop" AutomationProperties.Name="Crop tool" Style="{StaticResource ToolbarButton}" Content="⌗ Y" Click="ToolCrop_Click" />
          <Rectangle Width="{StaticResource MetricSeparatorWidth}" Height="{StaticResource MetricSeparatorHeight}" Fill="{StaticResource BrushRule}" Margin="{StaticResource MetricSeparatorMargin}" />
          <Button AutomationProperties.AutomationId="Color1" AutomationProperties.Name="Palette color 1" Style="{StaticResource ToolbarButton}" Content="1" Click="Color1_Click" />
          <Button AutomationProperties.AutomationId="Color2" AutomationProperties.Name="Palette color 2" Style="{StaticResource ToolbarButton}" Content="2" Click="Color2_Click" />
          <Button AutomationProperties.AutomationId="Color3" AutomationProperties.Name="Palette color 3" Style="{StaticResource ToolbarButton}" Content="3" Click="Color3_Click" />
          <Button AutomationProperties.AutomationId="Color4" AutomationProperties.Name="Palette color 4" Style="{StaticResource ToolbarButton}" Content="4" Click="Color4_Click" />
          <Button AutomationProperties.AutomationId="Color5" AutomationProperties.Name="Palette color 5" Style="{StaticResource ToolbarButton}" Content="5" Click="Color5_Click" />
          <Rectangle Width="{StaticResource MetricSeparatorWidth}" Height="{StaticResource MetricSeparatorHeight}" Fill="{StaticResource BrushRule}" Margin="{StaticResource MetricSeparatorMargin}" />
          <Button AutomationProperties.AutomationId="SizeSmall" AutomationProperties.Name="Small annotation size" Style="{StaticResource ToolbarButton}" Content="S Z" Click="SizeSmall_Click" />
          <Button AutomationProperties.AutomationId="SizeMedium" AutomationProperties.Name="Medium annotation size" Style="{StaticResource ToolbarButton}" Content="M X" Click="SizeMedium_Click" />
          <Button AutomationProperties.AutomationId="SizeLarge" AutomationProperties.Name="Large annotation size" Style="{StaticResource ToolbarButton}" Content="L C" Click="SizeLarge_Click" />
          <TextBox x:Name="TextValue"
                   AutomationProperties.AutomationId="TextValue"
                   Width="{StaticResource MetricTextInputWidth}"
                   Height="{StaticResource MetricTextInputHeight}"
                   Margin="{StaticResource MetricTextInputMargin}"
                   AcceptsReturn="True"
                   VerticalContentAlignment="Center"
                   Text="{Binding PendingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   KeyDown="TextValue_KeyDown" />
        </StackPanel>
        <TextBlock Grid.Column="1"
                   AutomationProperties.AutomationId="ZoomStatus"
                   VerticalAlignment="Center"
                   Margin="{StaticResource MetricHeaderMargin}"
                   Foreground="{StaticResource BrushMuted}"
                   Text="{Binding ZoomPercent}" />
      </Grid>

      <Border Margin="{StaticResource MetricEditorPadding}"
              CornerRadius="{StaticResource MetricEditorRadius}"
              BorderBrush="{StaticResource BrushRule}"
              BorderThickness="{StaticResource MetricBorderThickness}"
              Background="{StaticResource BrushPanel}">
        <editor:EditorCanvas x:Name="Canvas"
                             Focusable="True"
                             Margin="{StaticResource MetricCanvasMargin}"
                             ViewModel="{Binding}" />
      </Border>
    </DockPanel>
  </Border>
</Window>
