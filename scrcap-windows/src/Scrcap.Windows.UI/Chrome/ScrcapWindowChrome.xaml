<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:chrome="clr-namespace:Scrcap.Windows.UI.Chrome"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
  <Style x:Key="CaptionButton" TargetType="Button">
    <Setter Property="Width" Value="{StaticResource MetricCaptionButtonWidth}" />
    <Setter Property="Height" Value="{StaticResource MetricHeaderHeight}" />
    <Setter Property="Padding" Value="{StaticResource MetricNoThickness}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="{StaticResource MetricNoThickness}" />
    <Setter Property="Foreground" Value="{StaticResource BrushInk}" />
    <Setter Property="FontFamily" Value="{StaticResource FontIcon}" />
    <Setter Property="FontSize" Value="{StaticResource FontSizeChromeIcon}" />
    <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome"
                  Background="{TemplateBinding Background}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource BrushHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource BrushPressed}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{StaticResource BrushDanger}" />
        <Setter Property="Foreground" Value="{StaticResource BrushOnAccent}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type chrome:ScrcapWindowChrome}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type chrome:ScrcapWindowChrome}">
          <Border BorderBrush="{StaticResource BrushRule}"
                  BorderThickness="{StaticResource MetricBorderThickness}"
                  CornerRadius="{TemplateBinding FrameCornerRadius}"
                  Background="{StaticResource BrushChrome}">
            <DockPanel LastChildFill="True">
              <Grid DockPanel.Dock="Top"
                    Height="{StaticResource MetricHeaderHeight}"
                    Background="{StaticResource BrushChrome}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Rectangle Grid.ColumnSpan="4"
                           VerticalAlignment="Bottom"
                           Height="{StaticResource MetricSeparatorWidth}"
                           Fill="{StaticResource BrushRule}" />
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="{StaticResource MetricHeaderLeftInset}">
                  <Border Width="{StaticResource MetricLogoGlyphSize}"
                          Height="{StaticResource MetricLogoGlyphSize}"
                          BorderBrush="{StaticResource BrushInk}"
                          BorderThickness="{StaticResource MetricBorderThickness}"
                          CornerRadius="{StaticResource MetricLogoRadius}"
                          Margin="{StaticResource MetricLogoMargin}">
                    <Grid>
                      <Rectangle Width="{StaticResource MetricLogoDotSize}" Height="{StaticResource MetricLogoDotSize}" Fill="{StaticResource BrushInk}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Rectangle Width="{StaticResource MetricLogoLineSize}" Fill="{StaticResource BrushInk}" HorizontalAlignment="Center" />
                      <Rectangle Height="{StaticResource MetricLogoLineSize}" Fill="{StaticResource BrushInk}" VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                  <TextBlock Text="{TemplateBinding TitleText}"
                             VerticalAlignment="Center"
                             FontFamily="{StaticResource FontUi}"
                             FontSize="{StaticResource FontSizeBrand}"
                             FontWeight="Black"
                             Foreground="{StaticResource BrushInk}" />
                  <TextBlock Text="{TemplateBinding SubtitleText}"
                             VerticalAlignment="Center"
                             Margin="{StaticResource MetricPreferencesSubtitleMargin}"
                             FontFamily="{StaticResource FontUi}"
                             FontSize="{StaticResource FontSizeSmall}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource BrushMuted}" />
                </StackPanel>
                <ContentPresenter Grid.Column="2"
                                  Content="{TemplateBinding HeaderActions}"
                                  VerticalAlignment="Center"
                                  Margin="{StaticResource MetricHeaderActionMargin}" />
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                  <Button x:Name="PART_MinimizeButton"
                          AutomationProperties.AutomationId="CaptionMinimizeButton"
                          AutomationProperties.Name="Minimize"
                          Style="{StaticResource CaptionButton}"
                          Content="&#xE921;" />
                  <Button x:Name="PART_MaximizeButton"
                          AutomationProperties.AutomationId="CaptionMaximizeButton"
                          AutomationProperties.Name="Maximize or restore"
                          Style="{StaticResource CaptionButton}"
                          Content="{Binding MaximizeGlyph, RelativeSource={RelativeSource TemplatedParent}}"
                          chrome:WindowChromeBehavior.IsSnapLayoutMaximizeTarget="True" />
                  <Button x:Name="PART_CloseButton"
                          AutomationProperties.AutomationId="CaptionCloseButton"
                          AutomationProperties.Name="Close"
                          Style="{StaticResource CaptionCloseButton}"
                          Content="&#xE8BB;" />
                </StackPanel>
              </Grid>

              <ContentPresenter Content="{TemplateBinding Content}" />
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
