  <sys:Double x:Key="MetricOverlayCountdownFontSize">56</sys:Double>
  <sys:Double x:Key="MetricScrollingHudWidth">220</sys:Double>
  <sys:Double x:Key="MetricScrollingHudHeight">64</sys:Double>
  <sys:Double x:Key="MetricScrollingHudDot">9</sys:Double>
  <sys:Double x:Key="MetricScrollingHudStopMinWidth">54</sys:Double>
  <Thickness x:Key="MetricEditorPadding">16</Thickness>
  <Thickness x:Key="MetricBorderThickness">1</Thickness>
  <Thickness x:Key="MetricHeaderMargin">12,0</Thickness>
  <Thickness x:Key="MetricHeaderRightMargin">0,0,8,0</Thickness>
  <Thickness x:Key="MetricWindowMargin">12</Thickness>
  <Thickness x:Key="MetricPanelMargin">18</Thickness>
  <Thickness x:Key="MetricTopGap">0,16,0,0</Thickness>
  <Thickness x:Key="MetricSmallTopGap">0,10,0,0</Thickness>
  <Thickness x:Key="MetricButtonGapRight">0,0,8,0</Thickness>
  <Thickness x:Key="MetricPaletteGapRight">0,0,6,0</Thickness>
  <Thickness x:Key="MetricPickButtonMargin">8,0,0,0</Thickness>
  <Thickness x:Key="MetricTextInputMargin">8,0,0,0</Thickness>
  <Thickness x:Key="MetricToolbarButtonMargin">0,0,6,0</Thickness>
  <Thickness x:Key="MetricToolbarButtonPadding">8,0</Thickness>
  <Thickness x:Key="MetricSeparatorMargin">6,0,10,0</Thickness>
  <Thickness x:Key="MetricCanvasMargin">10</Thickness>
  <Thickness x:Key="MetricOverlayHintPadding">10,6</Thickness>
  <Thickness x:Key="MetricOverlayTagPadding">6,3</Thickness>
  <Thickness x:Key="MetricOverlayLabelPadding">8,4</Thickness>
  <Thickness x:Key="MetricScrollingHudPadding">12,9</Thickness>
  <Thickness x:Key="MetricScrollingHudStopPadding">10,4</Thickness>
  <CornerRadius x:Key="MetricPreferencesRadius">8</CornerRadius>
  <CornerRadius x:Key="MetricOverlayTagRadius">4</CornerRadius>

</ResourceDictionary>
