<Window x:Class="Scrcap.Windows.UI.Preferences.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="scrcap Preferences"
        Width="{StaticResource MetricPreferencesWidth}"
        Height="{StaticResource MetricPreferencesHeight}"
        MinWidth="{StaticResource MetricPreferencesMinWidth}"
        MinHeight="{StaticResource MetricPreferencesMinHeight}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushChrome}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="{StaticResource MetricPreferencesRadius}"
                        GlassFrameThickness="0"
                        NonClientFrameEdges="None"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
    </Style>
    <Style x:Key="RowLabel" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource BrushMuted}" />
      <Setter Property="Margin" Value="0,12,0,5" />
    </Style>
    <Style x:Key="ValueBadge" TargetType="TextBlock">
      <Setter Property="MinWidth" Value="54" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
      <Setter Property="Background" Value="{DynamicResource BrushActiveWash}" />
      <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="{StaticResource MetricBorderThickness}" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Padding" Value="{StaticResource MetricToolbarButtonPadding}" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource MetricChromeButtonRadius}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushHover}" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushPressed}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="{StaticResource MetricBorderThickness}" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CaretBrush" Value="{DynamicResource BrushAccent}" />
      <Setter Property="SelectionBrush" Value="{DynamicResource BrushActiveWash}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource MetricChromeButtonRadius}"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushRule}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="{StaticResource MetricBorderThickness}" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="9,0,30,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="Chrome"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="{StaticResource MetricChromeButtonRadius}"
                      SnapsToDevicePixels="True">
                <Grid>
                  <ContentPresenter x:Name="ContentSite"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center" />
                  <Path Width="{StaticResource MetricComboArrowWidth}"
                        Height="{StaticResource MetricComboArrowHeight}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="{StaticResource MetricComboArrowMargin}"
                        Data="M 0 0 L 4 4 L 8 0 Z"
                        Fill="{TemplateBinding Foreground}" />
                </Grid>
              </Border>
              <ToggleButton Background="Transparent"
                            BorderThickness="{StaticResource MetricNoThickness}"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            ClickMode="Press" />
              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom"
                     PopupAnimation="Fade">
                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        Background="{DynamicResource BrushWell}"
                        BorderBrush="{DynamicResource BrushRule}"
                        BorderThickness="{StaticResource MetricBorderThickness}"
                        SnapsToDevicePixels="True">
                  <ScrollViewer CanContentScroll="True">
                    <ItemsPresenter />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushHover}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushActiveWash}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid Background="Transparent"
                  SnapsToDevicePixels="True">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource MetricCheckboxColumnWidth}" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border x:Name="Box"
                      Width="{StaticResource MetricCheckboxSize}"
                      Height="{StaticResource MetricCheckboxSize}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Background="{DynamicResource BrushWell}"
                      BorderBrush="{DynamicResource BrushRule}"
                      BorderThickness="{StaticResource MetricBorderThickness}"
                      CornerRadius="{StaticResource MetricCheckboxRadius}">
                <Path x:Name="CheckMark"
                      Width="{StaticResource MetricCheckmarkWidth}"
                      Height="{StaticResource MetricCheckmarkHeight}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Data="M 0 3 L 3 6 L 9 0"
                      Stroke="{DynamicResource BrushOnAccent}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Visibility="Collapsed" />
              </Border>
              <ContentPresenter Grid.Column="1"
                                Margin="{StaticResource MetricCheckboxContentMargin}"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="{DynamicResource BrushAccent}" />
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SliderTrackButton" TargetType="RepeatButton">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Height" Value="4" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="{StaticResource MetricSliderTrackRadius}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SliderThumb" TargetType="Thumb">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="ThumbChrome"
                    Background="{DynamicResource BrushWell}"
                    BorderBrush="{DynamicResource BrushAccent}"
                    BorderThickness="{StaticResource MetricSliderThumbBorderThickness}"
                    CornerRadius="{StaticResource MetricSliderThumbRadius}" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource BrushActiveWash}" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource BrushAccent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Slider">
      <Setter Property="Height" Value="28" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid Height="{TemplateBinding Height}">
              <Border Height="{StaticResource MetricSliderTrackHeight}"
                      VerticalAlignment="Center"
                      Background="{DynamicResource BrushHairline}"
                      CornerRadius="{StaticResource MetricSliderTrackRadius}" />
              <Track x:Name="PART_Track"
                     VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                Background="{DynamicResource BrushAccent}"
                                Style="{StaticResource SliderTrackButton}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Style="{StaticResource SliderThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                Background="Transparent"
                                Style="{StaticResource SliderTrackButton}" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ColorSwatchButton" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BrushHairline}" />
      <Setter Property="BorderThickness" Value="{StaticResource MetricBorderThickness}" />
      <Setter Property="Height" Value="46" />
      <Setter Property="Padding" Value="{StaticResource MetricColorSwatchPadding}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource MetricChromeButtonRadius}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushPressed}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
    </Style>
    <Style TargetType="TabControl">
      <Setter Property="Background" Value="{DynamicResource BrushWell}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabControl">
            <DockPanel LastChildFill="True">
              <Border DockPanel.Dock="Top"
                      Height="{StaticResource MetricToolbarHeight}"
                      Background="{DynamicResource BrushChrome}"
                      BorderBrush="{DynamicResource BrushRule}"
                      BorderThickness="0,0,0,1">
                <TabPanel IsItemsHost="True"
                          VerticalAlignment="Stretch"
                          KeyboardNavigation.TabIndex="1" />
              </Border>
              <Border Background="{DynamicResource BrushWell}">
                <ContentPresenter ContentSource="SelectedContent" />
              </Border>
            </DockPanel>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource BrushInk}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Height" Value="{StaticResource MetricToolbarHeight}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="0,0,1,0"
                    MinWidth="{StaticResource MetricPreferencesTabMinWidth}">
              <ContentPresenter ContentSource="Header"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushHover}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushActiveWash}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Border CornerRadius="{StaticResource MetricPreferencesRadius}"
          Background="{DynamicResource BrushWindowFrame}"
          Margin="{StaticResource MetricWindowChromeInset}"
          SnapsToDevicePixels="True">
    <Border CornerRadius="{StaticResource MetricPreferencesInnerRadius}"
            Background="{DynamicResource BrushChrome}"
            Margin="{StaticResource MetricWindowFrameThickness}"
            SnapsToDevicePixels="True">
    <DockPanel LastChildFill="True">
      <Grid DockPanel.Dock="Top"
            Height="{StaticResource MetricHeaderHeight}"
            Background="{DynamicResource BrushChrome}"
            MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Rectangle Grid.ColumnSpan="2"
                   VerticalAlignment="Bottom"
                   Height="{StaticResource MetricSeparatorWidth}"
                   Fill="{DynamicResource BrushRule}" />
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="{StaticResource MetricHeaderBrandMargin}">
          <Border Width="{StaticResource MetricLogoGlyphSize}"
                  Height="{StaticResource MetricLogoGlyphSize}"
                  BorderBrush="{DynamicResource BrushInk}"
                  BorderThickness="{StaticResource MetricBorderThickness}"
                  CornerRadius="{StaticResource MetricLogoRadius}"
                  Margin="{StaticResource MetricLogoMargin}">
            <Grid>
              <Rectangle Width="{StaticResource MetricLogoDotSize}" Height="{StaticResource MetricLogoDotSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Rectangle Width="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" HorizontalAlignment="Center" />
              <Rectangle Height="{StaticResource MetricLogoLineSize}" Fill="{DynamicResource BrushInk}" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <TextBlock Text="SCRCAP"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeBrand}"
                     FontWeight="Black"
                     Foreground="{DynamicResource BrushInk}" />
          <TextBlock Text="Preferences"
                     VerticalAlignment="Center"
                     Margin="{StaticResource MetricPreferencesSubtitleMargin}"
                     FontFamily="{StaticResource FontUi}"
                     FontSize="{StaticResource FontSizeSmall}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushMuted}" />
        </StackPanel>
        <Button Grid.Column="1"
                AutomationProperties.AutomationId="ClosePreferences"
                AutomationProperties.Name="Close preferences"
                Content="&#xE711;"
                FontFamily="{StaticResource FontIcon}"
                Width="{StaticResource MetricIconButtonWidth}"
                Height="{StaticResource MetricIconButtonHeight}"
                Margin="{StaticResource MetricPreferencesCloseMargin}"
                Click="Close_Click" />
      </Grid>

      <TextBlock DockPanel.Dock="Top"
                 AutomationProperties.AutomationId="PreferencesError"
                 Text="{Binding LastError}"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource BrushDanger}">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="{StaticResource MetricPanelMargin}" />
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Margin" Value="{StaticResource MetricToolbarButtonMargin}" />
              </Trigger>
              <Trigger Property="Text" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Margin" Value="{StaticResource MetricToolbarButtonMargin}" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <TabControl AutomationProperties.AutomationId="PreferencesTabs"
                  Margin="{StaticResource MetricToolbarButtonMargin}">
        <TabItem Header="General">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="{StaticResource MetricPanelMargin}">
              <TextBlock Style="{StaticResource RowLabel}" Text="Theme" />
              <ComboBox AutomationProperties.AutomationId="ThemeMode" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay}" />
              <CheckBox AutomationProperties.AutomationId="LaunchAtLogin" Content="Launch at login" IsChecked="{Binding LaunchAtLogin, Mode=TwoWay}" Margin="{StaticResource MetricTopGap}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Reset" />
              <Button AutomationProperties.AutomationId="ResetAllPreferences"
                      AutomationProperties.Name="Reset all settings"
                      Content="Reset all"
                      HorizontalAlignment="Left"
                      MinWidth="{StaticResource MetricCommandButtonMinWidth}"
                      BorderBrush="{DynamicResource BrushDanger}"
                      Foreground="{DynamicResource BrushDanger}"
                      Click="ResetAll_Click" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Capture">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="{StaticResource MetricPanelMargin}">
              <TextBlock Style="{StaticResource RowLabel}" Text="Region after capture" />
              <ComboBox AutomationProperties.AutomationId="RegionAfterCapture" ItemsSource="{Binding CaptureBehaviors}" SelectedItem="{Binding RegionAfterCapture, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Window after capture" />
              <ComboBox AutomationProperties.AutomationId="WindowAfterCapture" ItemsSource="{Binding CaptureBehaviors}" SelectedItem="{Binding WindowAfterCapture, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Fullscreen after capture" />
              <ComboBox AutomationProperties.AutomationId="FullscreenAfterCapture" ItemsSource="{Binding CaptureBehaviors}" SelectedItem="{Binding FullscreenAfterCapture, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Scrolling after capture" />
              <ComboBox AutomationProperties.AutomationId="ScrollingAfterCapture" ItemsSource="{Binding CaptureBehaviors}" SelectedItem="{Binding ScrollingAfterCapture, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Window target" />
              <ComboBox AutomationProperties.AutomationId="WindowCaptureTarget" ItemsSource="{Binding WindowTargets}" SelectedItem="{Binding WindowCaptureTarget, Mode=TwoWay}" />
              <CheckBox AutomationProperties.AutomationId="IncludeCursor" Content="Include cursor" IsChecked="{Binding IncludeCursor, Mode=TwoWay}" Margin="{StaticResource MetricTopGap}" />
              <CheckBox AutomationProperties.AutomationId="IncludeWindowShadow" Content="Include window shadow" IsChecked="{Binding IncludeWindowShadow, Mode=TwoWay}" />
              <CheckBox AutomationProperties.AutomationId="WindowBackgroundTransparent" Content="Transparent window background" IsChecked="{Binding WindowBackgroundTransparent, Mode=TwoWay}" />
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource RowLabel}" Text="Window background" />
                <TextBlock AutomationProperties.AutomationId="WindowBackgroundValue"
                           DockPanel.Dock="Right"
                           Style="{StaticResource ValueBadge}"
                           Margin="{StaticResource MetricValueBadgeMargin}"
                           Text="{Binding WindowBackgroundHex}" />
              </DockPanel>
              <Button AutomationProperties.AutomationId="WindowBackgroundHex"
                      AutomationProperties.Name="Pick window background color"
                      Style="{StaticResource ColorSwatchButton}"
                      Tag="WindowBackgroundHex"
                      ToolTip="{Binding WindowBackgroundHex}"
                      Click="PickColor_Click">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource MetricColorSwatchPreviewWidth}" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Rectangle Fill="{Binding WindowBackgroundBrush}"
                             Stroke="{DynamicResource BrushRule}"
                             StrokeThickness="1"
                             RadiusX="{StaticResource MetricColorSwatchRadius}"
                             RadiusY="{StaticResource MetricColorSwatchRadius}" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Margin="{StaticResource MetricColorSwatchTextMargin}"
                             FontFamily="{StaticResource FontMono}"
                             Text="{Binding WindowBackgroundHex}" />
                </Grid>
              </Button>
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource RowLabel}" Text="Capture delay seconds" />
                <TextBlock AutomationProperties.AutomationId="CaptureDelaySecondsValue"
                           DockPanel.Dock="Right"
                           Style="{StaticResource ValueBadge}"
                           Margin="{StaticResource MetricValueBadgeMargin}"
                           Text="{Binding ElementName=CaptureDelaySlider, Path=Value, StringFormat={}{0:0}s}" />
              </DockPanel>
              <Slider x:Name="CaptureDelaySlider" AutomationProperties.AutomationId="CaptureDelaySeconds" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding CaptureDelaySeconds, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Scrolling max height" />
              <TextBox AutomationProperties.AutomationId="ScrollingMaxHeight" Text="{Binding ScrollingMaxHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Shortcuts">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="{StaticResource MetricPanelMargin}">
              <TextBlock Style="{StaticResource RowLabel}" Text="Capture region" />
              <TextBox AutomationProperties.AutomationId="CaptureRegionHotkey" Tag="CaptureRegion" IsReadOnly="True" Text="{Binding CaptureRegionHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Capture window" />
              <TextBox AutomationProperties.AutomationId="CaptureWindowHotkey" Tag="CaptureWindow" IsReadOnly="True" Text="{Binding CaptureWindowHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Capture fullscreen" />
              <TextBox AutomationProperties.AutomationId="CaptureFullscreenHotkey" Tag="CaptureFullscreen" IsReadOnly="True" Text="{Binding CaptureFullscreenHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Scrolling capture" />
              <TextBox AutomationProperties.AutomationId="CaptureScrollingHotkey" Tag="CaptureScrolling" IsReadOnly="True" Text="{Binding CaptureScrollingHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Delayed capture" />
              <TextBox AutomationProperties.AutomationId="CaptureDelayedHotkey" Tag="CaptureDelayed" IsReadOnly="True" Text="{Binding CaptureDelayedHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Repeat last" />
              <TextBox AutomationProperties.AutomationId="RepeatLastHotkey" Tag="RepeatLast" IsReadOnly="True" Text="{Binding RepeatLastHotkeyDisplay, Mode=OneWay}" GotKeyboardFocus="ShortcutTextBox_GotKeyboardFocus" LostKeyboardFocus="ShortcutTextBox_LostKeyboardFocus" PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" />
              <TextBlock AutomationProperties.AutomationId="ShortcutRecorderStatus"
                         Margin="{StaticResource MetricSmallTopGap}"
                         Foreground="{DynamicResource BrushMuted}"
                         Text="{Binding ShortcutRecorderStatus}" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Editor">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="{StaticResource MetricPanelMargin}">
              <TextBlock Style="{StaticResource RowLabel}" Text="Palette" />
              <UniformGrid Columns="5">
                <Button AutomationProperties.AutomationId="Palette1" AutomationProperties.Name="Pick palette color 1" Style="{StaticResource ColorSwatchButton}" Tag="Palette1" ToolTip="{Binding Palette1}" Margin="{StaticResource MetricPaletteGapRight}" Click="PickColor_Click">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Rectangle Fill="{Binding Palette1Brush}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" RadiusX="{StaticResource MetricColorSwatchRadius}" RadiusY="{StaticResource MetricColorSwatchRadius}" />
                    <TextBlock Grid.Row="1" Text="{Binding Palette1}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizePaletteValue}" TextAlignment="Center" Margin="{StaticResource MetricPaletteValueMargin}" />
                  </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="Palette2" AutomationProperties.Name="Pick palette color 2" Style="{StaticResource ColorSwatchButton}" Tag="Palette2" ToolTip="{Binding Palette2}" Margin="{StaticResource MetricPaletteGapRight}" Click="PickColor_Click">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Rectangle Fill="{Binding Palette2Brush}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" RadiusX="{StaticResource MetricColorSwatchRadius}" RadiusY="{StaticResource MetricColorSwatchRadius}" />
                    <TextBlock Grid.Row="1" Text="{Binding Palette2}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizePaletteValue}" TextAlignment="Center" Margin="{StaticResource MetricPaletteValueMargin}" />
                  </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="Palette3" AutomationProperties.Name="Pick palette color 3" Style="{StaticResource ColorSwatchButton}" Tag="Palette3" ToolTip="{Binding Palette3}" Margin="{StaticResource MetricPaletteGapRight}" Click="PickColor_Click">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Rectangle Fill="{Binding Palette3Brush}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" RadiusX="{StaticResource MetricColorSwatchRadius}" RadiusY="{StaticResource MetricColorSwatchRadius}" />
                    <TextBlock Grid.Row="1" Text="{Binding Palette3}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizePaletteValue}" TextAlignment="Center" Margin="{StaticResource MetricPaletteValueMargin}" />
                  </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="Palette4" AutomationProperties.Name="Pick palette color 4" Style="{StaticResource ColorSwatchButton}" Tag="Palette4" ToolTip="{Binding Palette4}" Margin="{StaticResource MetricPaletteGapRight}" Click="PickColor_Click">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Rectangle Fill="{Binding Palette4Brush}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" RadiusX="{StaticResource MetricColorSwatchRadius}" RadiusY="{StaticResource MetricColorSwatchRadius}" />
                    <TextBlock Grid.Row="1" Text="{Binding Palette4}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizePaletteValue}" TextAlignment="Center" Margin="{StaticResource MetricPaletteValueMargin}" />
                  </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="Palette5" AutomationProperties.Name="Pick palette color 5" Style="{StaticResource ColorSwatchButton}" Tag="Palette5" ToolTip="{Binding Palette5}" Click="PickColor_Click">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Rectangle Fill="{Binding Palette5Brush}" Stroke="{DynamicResource BrushRule}" StrokeThickness="1" RadiusX="{StaticResource MetricColorSwatchRadius}" RadiusY="{StaticResource MetricColorSwatchRadius}" />
                    <TextBlock Grid.Row="1" Text="{Binding Palette5}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizePaletteValue}" TextAlignment="Center" Margin="{StaticResource MetricPaletteValueMargin}" />
                  </Grid>
                </Button>
              </UniformGrid>
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource RowLabel}" Text="Stroke width" />
                <TextBlock AutomationProperties.AutomationId="StrokeWidthValue"
                           DockPanel.Dock="Right"
                           Style="{StaticResource ValueBadge}"
                           Margin="{StaticResource MetricValueBadgeMargin}"
                           Text="{Binding ElementName=StrokeWidthSlider, Path=Value, StringFormat={}{0:0.#} px}" />
              </DockPanel>
              <Slider x:Name="StrokeWidthSlider" AutomationProperties.AutomationId="StrokeWidth" Minimum="1" Maximum="8" Value="{Binding StrokeWidth, Mode=TwoWay}" />
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource RowLabel}" Text="Text size" />
                <TextBlock AutomationProperties.AutomationId="TextSizeValue"
                           DockPanel.Dock="Right"
                           Style="{StaticResource ValueBadge}"
                           Margin="{StaticResource MetricValueBadgeMargin}"
                           Text="{Binding ElementName=TextSizeSlider, Path=Value, StringFormat={}{0:0} pt}" />
              </DockPanel>
              <Slider x:Name="TextSizeSlider" AutomationProperties.AutomationId="TextSize" Minimum="10" Maximum="36" Value="{Binding TextSize, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Return behavior" />
              <ComboBox AutomationProperties.AutomationId="TextEnterBehavior" ItemsSource="{Binding TextEnterBehaviors}" SelectedItem="{Binding TextEnterBehavior, Mode=TwoWay}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Esc behavior" />
              <ComboBox AutomationProperties.AutomationId="EscBehavior" ItemsSource="{Binding EscBehaviors}" SelectedItem="{Binding EscBehavior, Mode=TwoWay}" />
              <CheckBox AutomationProperties.AutomationId="AutoExpandCanvas" Content="Auto-expand canvas" IsChecked="{Binding AutoExpandCanvas, Mode=TwoWay}" Margin="{StaticResource MetricTopGap}" />
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource RowLabel}" Text="Canvas extension background" />
                <TextBlock AutomationProperties.AutomationId="CanvasExtensionBackgroundValue"
                           DockPanel.Dock="Right"
                           Style="{StaticResource ValueBadge}"
                           Margin="{StaticResource MetricValueBadgeMargin}"
                           Text="{Binding CanvasExtensionBackgroundHex}" />
              </DockPanel>
              <Button AutomationProperties.AutomationId="CanvasExtensionBackgroundHex"
                      AutomationProperties.Name="Pick canvas extension background color"
                      Style="{StaticResource ColorSwatchButton}"
                      Tag="CanvasExtensionBackgroundHex"
                      ToolTip="{Binding CanvasExtensionBackgroundHex}"
                      Click="PickColor_Click">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource MetricColorSwatchPreviewWidth}" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Rectangle Fill="{Binding CanvasExtensionBackgroundBrush}"
                             Stroke="{DynamicResource BrushRule}"
                             StrokeThickness="1"
                             RadiusX="{StaticResource MetricColorSwatchRadius}"
                             RadiusY="{StaticResource MetricColorSwatchRadius}" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Margin="{StaticResource MetricColorSwatchTextMargin}"
                             FontFamily="{StaticResource FontMono}"
                             Text="{Binding CanvasExtensionBackgroundHex}" />
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Output">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="{StaticResource MetricPanelMargin}">
              <TextBlock Style="{StaticResource RowLabel}" Text="Save folder" />
              <DockPanel>
                <Button DockPanel.Dock="Right" AutomationProperties.AutomationId="PickSaveFolder" AutomationProperties.Name="Pick save folder" Content="Pick" Margin="{StaticResource MetricPickButtonMargin}" Click="PickSaveFolder_Click" />
                <TextBox AutomationProperties.AutomationId="SaveFolder" Text="{Binding SaveFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </DockPanel>
              <TextBlock Style="{StaticResource RowLabel}" Text="Filename pattern" />
              <TextBox AutomationProperties.AutomationId="FilenamePattern" Text="{Binding FilenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Style="{StaticResource RowLabel}" Text="Export scale" />
              <ComboBox AutomationProperties.AutomationId="ExportScale" ItemsSource="{Binding ExportScales}" SelectedItem="{Binding ExportScale, Mode=TwoWay}" />
              <CheckBox AutomationProperties.AutomationId="SuppressCopyNotification" Content="Suppress copy notification" IsChecked="{Binding SuppressCopyNotification, Mode=TwoWay}" Margin="{StaticResource MetricTopGap}" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="About">
          <StackPanel Margin="{StaticResource MetricPanelMargin}">
            <TextBlock Text="scrcap for Windows" FontWeight="Bold" Foreground="{DynamicResource BrushInk}" />
            <TextBlock Text="{Binding VersionText, StringFormat=Version {0}}" Margin="{StaticResource MetricSmallTopGap}" />
            <TextBlock Text="{Binding BuildChannel, StringFormat=Build channel: {0}}" />
            <Button AutomationProperties.AutomationId="OpenSource"
                    AutomationProperties.Name="Open scrcap source repository"
                    Content="github.com/kubre/scrcap"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource MetricSmallTopGap}"
                    Click="OpenSource_Click" />
            <Button AutomationProperties.AutomationId="CheckForUpdates"
                    AutomationProperties.Name="Check for updates"
                    Content="Check for Updates..."
                    HorizontalAlignment="Left"
                    Margin="{StaticResource MetricSmallTopGap}"
                    Click="CheckForUpdates_Click" />
            <TextBlock AutomationProperties.AutomationId="UpdateStatus"
                       Text="{Binding UpdateStatus}"
                       TextWrapping="Wrap"
                       Margin="{StaticResource MetricSmallTopGap}" />
            <Button AutomationProperties.AutomationId="OpenLatestRelease"
                    AutomationProperties.Name="Open latest release"
                    Content="Open latest release"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource MetricSmallTopGap}"
                    IsEnabled="{Binding HasLatestRelease}"
                    Click="OpenLatestRelease_Click" />
            <TextBlock Text="License and credits: scrcap project contributors." Margin="{StaticResource MetricSmallTopGap}" />
          </StackPanel>
        </TabItem>
      </TabControl>
    </DockPanel>
    </Border>
  </Border>
</Window>
